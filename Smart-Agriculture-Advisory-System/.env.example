# Environment configuration for Agriculture Advisory System

# ===== Core Settings =====
ENV=development
HOST=0.0.0.0
PORT=8000
DEBUG=True
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# ===== Database Configuration =====
# PostgreSQL with PostGIS
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/agriculture_db
SQL_ECHO=False
POOL_SIZE=10
MAX_OVERFLOW=20

# ===== Authentication & Security =====
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480  # 8 hours
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== SMS Gateway Configuration =====
# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Alternative: Karix (India-focused)
KARIX_API_KEY=your_karix_api_key
KARIX_SENDER_ID=SenderID

SMS_PROVIDER=twilio  # or karix
SMS_ENABLED=True

# ===== Weather API Keys =====
OPENWEATHERMAP_API_KEY=your_api_key
ECMWF_API_KEY=your_api_key_if_available  # Requires paid account

# ===== Logging & Monitoring =====
LOG_LEVEL=INFO
ELK_HOST=localhost
ELK_PORT=9200
ENABLE_MONITORING=True

# ===== Redis Configuration (for message queue, caching) =====
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ===== File Storage =====
STORAGE_TYPE=local  # local, s3, gcs
LOCAL_STORAGE_PATH=./storage
AWS_BUCKET_NAME=agriculture-advisory-prod
AWS_REGION=us-east-1

# ===== Feature Flags =====
ENABLE_BIAS_CORRECTION=True
ENABLE_SHAP_EXPLANATIONS=True
ENABLE_ML_ADVISORY=False  # Set to True after model training
ENABLE_IOT_INTEGRATION=False

# ===== Pilot Configuration =====
PILOT_DISTRICT=Kaira
PILOT_STATE=Gujarat
PILOT_CROP=Rice
PILOT_FARMERS_TARGET=500

# ===== Notifications =====
FCM_PROJECT_ID=your_fcm_project
FCM_PRIVATE_KEY_PATH=./credentials/fcm_service_account.json

# ===== Email (for admin notifications) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ADMIN_EMAIL=admin@agricultureadvisory.com
